{
  "name": "effisend",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "postinstall": "patch-package",
    "rec": "adb reverse tcp:8081 tcp:8081",
    "depcheck": "npx depcheck",
    "build": "cd android && gradlew assembleRelease && cd ..",
    "prebuild": "npx expo prebuild",
    "prebuildc": "npx expo prebuild --clean",
    "clean": "cd android && gradlew clean && cd ..",
    "deploy": "cd android && gradlew assembleRelease && adb install -r app/build/outputs/apk/release/app-release.apk",
    "installapp": "adb install -r android/app/build/outputs/apk/release/app-release.apk",
    "playbuild": "node scripts/update-and-build.js"
  },
  "dependencies": {
    "@bam.tech/react-native-image-resizer": "^3.0.11",
    "@expo-google-fonts/exo-2": "^0.4.2",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-clipboard/clipboard": "^1.16.3",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "ethers": "^6.15.0",
    "expo": "~54.0.25",
    "expo-blur": "~15.0.7",
    "expo-camera": "~17.0.9",
    "expo-constants": "~18.0.10",
    "expo-crypto": "~15.0.7",
    "expo-font": "~14.0.9",
    "expo-haptics": "~15.0.7",
    "expo-image": "~3.0.10",
    "expo-image-manipulator": "~14.0.7",
    "expo-linear-gradient": "~15.0.7",
    "expo-linking": "~8.0.9",
    "expo-print": "~15.0.7",
    "expo-router": "~6.0.15",
    "expo-secure-store": "~15.0.7",
    "expo-splash-screen": "~31.0.11",
    "expo-status-bar": "~3.0.8",
    "expo-symbols": "~1.0.7",
    "expo-system-ui": "~6.0.8",
    "expo-web-browser": "~15.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-camera-kit": "^16.1.3",
    "react-native-fs": "^2.20.0",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-qrcode-svg": "^6.3.20",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.15.0",
    "react-native-virtual-keyboard": "^1.2.2",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "starknet": "^7.6.4"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "patch-package": "^8.0.1",
    "typescript": "~5.9.2"
  },
  "private": true
}
