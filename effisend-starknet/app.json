{
  "expo": {
    "name": "Effisend",
    "slug": "Effisend",
    "version": "1.0.4",
    "orientation": "portrait",
    "icon": "./src/assets/images/logoCenter.png",
    "scheme": "effisend",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "versionCode": 5,
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./src/assets/images/logoCenter.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.altaga.effisenda.starknet"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "./scripts/withAndroidBuildFixes.js",
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./src/assets/images/logoR.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}